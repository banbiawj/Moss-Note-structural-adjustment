{
  "name": "fastapi-full-stack-template",
  "private": true,
  "workspaces": [
    "frontend",
    "frontend-web"
  ],
  "scripts": {
    "dev": "bun run --filter frontend dev",
    "dev:web": "bun run --filter frontend-web dev",
    "build:web": "bun run --filter frontend-web build",
    "lint": "bun run --filter frontend lint",
    "lint:web": "bun run --filter frontend-web lint",
    "test": "bun run --filter frontend test",
    "test:web:structure": "node frontend-web/tests/scaffold.test.mjs",
    "test:ui": "bun run --filter frontend test:ui"
  }
}
